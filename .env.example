# ═══════════════════════════════════════════
# DEGEN247 Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════

# ─── Solana RPC ───────────────────────────
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_RPC_FALLBACK=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=your_helius_api_key

# ─── Wallet ──────────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key
OWNER_WALLET_ADDRESS=your_owner_pubkey
OWNER_AUTH_TOKEN=random_string_for_key_export

# ─── LLM (OpenRouter) ───────────────────
OPENROUTER_API_KEY=sk-or-v1-your_key

# ─── Telegram ────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ─── LP Agent API ────────────────────────
LPAGENT_API_KEY=your_lpagent_key
LPAGENT_API_BASE=https://api.lpagent.io

# ─── Runtime ─────────────────────────────
DRY_RUN=true
DB_PATH=./data/degen247.sqlite
